# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Backend (FastAPI) ──────────────────────────────────────────────────────────
VAPI_PRIVATE_API_KEY=your_vapi_private_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# Optional: browser Web SDK public key for WebRTC demo endpoint
VAPI_PUBLIC_API_KEY=your_vapi_public_key_here

# Optional overrides
# VAPI_BASE_URL=https://api.vapi.ai
# LOG_LEVEL=INFO
# CORS allowlist for frontend origins (comma-separated or JSON array)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (UI only) ────────────────────────────────────────────────────────
# URL the browser uses to reach the backend (must be externally accessible).
# Frontend fetches runtime call config from /api/frontend/call-config.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
